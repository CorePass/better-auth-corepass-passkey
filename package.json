	"files": ["dist"],
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"better-auth": ">=1.0.0",
		"@better-auth/passkey": ">=1.0.0"
	},
	"dependencies": {
		"@noble/curves": "^1.6.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@better-auth/passkey": "^1.5.4",
		"better-auth": "^1.5.4",
		"typescript": "^5.0.0"
	}
